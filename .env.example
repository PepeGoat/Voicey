# VoiceStudio — API Keys
# Copy this file to .env and fill in the keys for each service you sign up for.
# The more providers you configure, the longer your free tiers last —
# synthesis requests rotate evenly across all configured providers.
#
# Every service below has a free tier — no card needed to start.
# ─────────────────────────────────────────────────────────────────────────────

# ElevenLabs — https://elevenlabs.io
# Free tier: 10,000 characters/month · 3 custom voices
# Get key: Profile → API Keys
ELEVENLABS_API_KEY=

# Play.ht — https://play.ht
# Free tier: 12,500 words/month
# Get keys: Dashboard → API Access
PLAYHT_SECRET_KEY=
PLAYHT_USER_ID=

# Cartesia — https://cartesia.ai
# Free tier: $5 credit/month (renews monthly)
# Get key: Dashboard → API Keys
CARTESIA_API_KEY=

# LMNT — https://lmnt.com
# Free tier: 500 speech utterances/month
# Get key: Dashboard → API Key
LMNT_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Optional — security keys (auto-generated defaults are fine for local use)
# SECRET_KEY=change-me-for-production
# JWT_SECRET=change-me-for-production
